rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: uid, email, displayName, role, createdAt
    //
    // Collection: cached_events
    // Fields: id, eventName, description, location, date, imageUrl, source, ticketUrl, eventVector, cachedAt
    //
    // Collection: metadata
    // Fields: lastSearchTimestamp
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "rishikajd123@gmail.com");
    }

    // Rules
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /cached_events/{eventId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /metadata/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
